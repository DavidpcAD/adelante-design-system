{
  "servers": {
    "figma": {
      "url": "https://mcp.figma.com/mcp",
      "type": "http",
      "headers": {
        "Authorization": "Bearer ${input:figma_token}"
      }
    }
  },
  "inputs": [
    {
      "id": "figma_token",
      "type": "promptString",
      "description": "Figma Personal Access Token (file_content:read)",
      "password": true
    }
  ]
}
